generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  category      String
  subcategory   String
  price         Float
  image         String
  badge         String?
  isExclusive   Boolean  @default(false)
  sku           String   @unique
  stock         Int      @default(0)
  description   String
  dimensions    String
  weight        String
  images        String[]
  colors        Json?    // Stores { name: string; hex: string }[]
  originalPrice Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id                   String   @id // e.g., #ORD-1234
  customerName         String
  initials             String
  avatarClass          String
  date                 String
  amount               Float
  status               String   // PROCESSING, PACKED, READY_TO_DISPATCH, SHIPPED, DELIVERED, REFUNDED
  trackingLink         String?
  trackingPartner      String?
  paymentMethod        String?  @default("Online")
  refundRequested      Boolean  @default(false)
  shiprocketOrderId    String?
  shiprocketShipmentId String?
  awbCode              String?
  items                Json?    // Stores { id: number; name: string; price: number; image: string; quantity: number }[]
  shippingAddress      Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?   @unique
  pin           String?   // Bcrypt-hashed 6-digit PIN
  
  // Marbie Specific Fields
  joinDate      String?
  totalOrders   Int       @default(0)
  lifetimeSpend Float     @default(0)
  tier          String?   @default("COLLECTOR")
  
  accounts      Account[]
  sessions      Session[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Stores pending OTP sessions during login/registration
model OtpToken {
  id          String   @id @default(cuid())
  phone       String   // E.164 format e.g. 919876543210
  email       String?  // Only for new user registration
  otp         String?  // The generated OTP sent via email
  pinHash     String?  // Hashed PIN stored temporarily during registration
  isNewUser   Boolean  @default(false)
  expires     DateTime // 5 minutes from creation
  createdAt   DateTime @default(now())

  @@index([phone])
}

model Review {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  time      String
  rating    Int
  content   String
  product   String
  verified  Boolean  @default(true)
  flagged    Boolean  @default(false)
  isFeatured Boolean  @default(false)
  image      String
  criticism  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id                 Int      @id @default(1) // Singleton
  isMaintenanceMode  Boolean  @default(false)
  heroCarouselRatio  String?
  featuredProductIds String[]
  productCategories  String[]
  labels             Json?
  marketing          Json?
  categories         Json?
  materials          String[]
  navigation         Json?
  footer             Json?
  carousel           Json?
  storefront         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Voucher {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  discountType   String   @default("PERCENTAGE") // "PERCENTAGE" or "FIXED"
  discountValue  Float
  minOrderAmount Float    @default(0)
  maxDiscount    Float?   
  maxUsers       Int      @default(100)
  usedCount      Int      @default(0)
  isActive       Boolean  @default(true)
  expiresAt      String?  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  date      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id         String   @id @default(uuid())
  subject    String
  banner     String
  title      String
  body       String
  ctaText    String
  ctaLink    String
  date       String
  recipients Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
